generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  active
  paused
  suspended
  banned
}

enum InstagramConnectionStatus {
  not_connected
  code_generated
  approval_pending
  approved
  rejected
}

enum AppRole {
  admin
  superadmin
  user
}

enum InstagramVerificationStatus {
  draft
  pending
  verified
  failed
  expired
  submitted
  approved
  rejected
}

model User {
  id                        String                    @id @default(cuid())
  email                     String                    @unique
  name                      String
  passwordHash              String
  accountStatus             AccountStatus             @default(active)
  instagramConnectionStatus InstagramConnectionStatus @default(not_connected)
  instagramUsername         String?
  instagramUserId           String?                   @unique
  instagramVerified         Boolean                   @default(false)
  verificationCode          String?
  followersCount            Int                       @default(0)
  instagramReviewSubmittedAt DateTime?
  instagramReviewReviewedAt DateTime?
  instagramReviewNotes      String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  roles                     UserRole[]
  sessions                  Session[]
  adminLoginActivities      AdminLoginActivity[]
  notifications             Notification[]
  submissions               Submission[]
  instagramVerificationRequest InstagramVerificationRequest? @relation("InstagramVerificationUser")
  reviewedInstagramVerifications InstagramVerificationRequest[] @relation("InstagramVerificationReviewer")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      AppRole  @default(user)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model SignupOtp {
  id         String   @id @default(cuid())
  email      String   @unique
  otpHash    String
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminSignupOtp {
  id         String   @id @default(cuid())
  email      String   @unique
  otpHash    String
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminLoginActivity {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InstagramVerificationRequest {
  id               String                      @id @default(cuid())
  userId           String                      @unique
  instagramUsername String
  instagramUserId  String
  followersCount   Int
  verificationCode String
  status           InstagramVerificationStatus @default(draft)
  submittedAt      DateTime?
  expiresAt        DateTime?
  checkedAt        DateTime?
  checkedBio       String?
  checkedFollowers Int?
  bioContainsToken Boolean?
  followersMatch   Boolean?
  reviewedAt       DateTime?
  reviewerId       String?
  reviewNotes      String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  user             User                        @relation("InstagramVerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer         User?                       @relation("InstagramVerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Campaign {
  id                    String       @id @default(cuid())
  title                 String
  description           String
  category              String
  rewardPerMillionViews Int          @default(100)
  rules                 String[]
  status                String       @default("Active")
  imageUrl              String?
  createdByAdminId      String?
  createdAt             DateTime     @default(now())
  submissions           Submission[]
}

model Submission {
  id                   String    @id @default(cuid())
  userId               String
  campaignId           String
  reelUrl              String
  normalizedReelUrl    String?   @unique
  reelCode             String?   @unique
  reelUploadedAt       DateTime  @default(now())
  submissionClosesAt   DateTime  @default(now())
  status               String    @default("Pending")
  views                Int       @default(0)
  playCount            Int       @default(0)
  likesCount           Int       @default(0)
  commentsCount        Int       @default(0)
  analyticsSource      String?
  analyticsSyncedAt    DateTime?
  apifyDatasetItemId   String?
  rejectionReason      String?
  earnings             Decimal   @default(0)
  reviewedAt           DateTime?
  reviewedByAdmin      String?
  submittedAt          DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign             Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([userId, submittedAt])
  @@index([campaignId, submittedAt])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
